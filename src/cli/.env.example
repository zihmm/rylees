# Required
#RYLEES_API_URL=http://api.rylees.test/v1
RYLEES_API_URL=https://api.rylees.ai/v1
RYLEES_API_TOKEN=
RYLEES_PROJECT_TOKEN=
OPENAI_API_KEY=

# Optional — overrides the temperature fetched from the API
# RYLEES_LLM_TEMPERATURE=0.5

# Optional — overrides the default model
RYLEES_LLM_MODEL=gpt-5.5

# Optional — LangSmith tracing for LLM requests (off unless LANGSMITH_TRACING is truthy)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=rylees-cli
# Optional — override for self-hosted / EU region (default: https://api.smith.langchain.com)
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com