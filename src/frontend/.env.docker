# Used by the dockerized dev frontend build (compose.dev.yaml runs
# `vite build --watch --mode docker`). Apache serves the static build, so the
# SPA needs the absolute local API host — not the Vite-proxied `/v1`.
VITE_API_BASE_URL=http://api.rylees.test/v1

VITE_HISTORY_BASE_DOMAIN=http://rylees.test