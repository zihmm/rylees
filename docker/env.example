# Copy to a root-level .env to override compose defaults.
#   cp docker/env.example .env

# ---------------------------------------------------------------------------
# Shared
# ---------------------------------------------------------------------------
# Dev: rylees.test  |  Prod: rylees.ai
APP_DOMAIN=rylees.test
# Host port Apache is published on.
WEB_PORT=80

# ---------------------------------------------------------------------------
# Dev database (bundled postgres container)
# ---------------------------------------------------------------------------
DB_DATABASE=rylees
DB_USERNAME=rylees
DB_PASSWORD=rylees
# Host port the dev postgres is published on (change if 5432 is taken).
DB_PORT_HOST=5432

# ---------------------------------------------------------------------------
# Prod — secrets (used by compose.prod.yaml)
# ---------------------------------------------------------------------------
# Prod runs its own local postgres container (not exposed to the internet). The
# DB_DATABASE / DB_USERNAME / DB_PASSWORD above seed that container — set strong
# values for production. DB_HOST defaults to the `postgres` service; only set it
# to override with an external host.
# APP_KEY=base64:...            # php artisan key:generate --show
# APP_URL=https://api.rylees.ai
# DB_HOST=postgres
# DB_PORT=5432
# MAIL_MAILER=smtp
# MAIL_HOST=
# MAIL_PORT=
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS=
# OPENAI_API_KEY=
